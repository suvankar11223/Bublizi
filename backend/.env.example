# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
NODE_ENV=development

# ============================================================================
# DATABASE
# ============================================================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024

# ============================================================================
# REDIS CONFIGURATION (REQUIRED IN PRODUCTION)
# ============================================================================
# Upstash Redis REST API (for rate limiting and sequence numbers)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ioredis Configuration (for BullMQ queues)
REDIS_HOST=your-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_TLS=true

# ============================================================================
# CLOUDINARY (File Uploads)
# ============================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================================
# LIVEKIT (Video/Voice Calls)
# ============================================================================
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WS_URL=wss://your-instance.livekit.cloud

# ============================================================================
# GEMINI AI
# ============================================================================
GEMINI_API_KEY=your_gemini_api_key
AI_BOT_USER_ID=your_ai_bot_user_id

# ============================================================================
# SMS (OTP)
# ============================================================================
FAST2SMS_API_KEY=your_fast2sms_api_key

# ============================================================================
# STREAM CHAT (Optional)
# ============================================================================
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret
