# ========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env.production and fill in your values

# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ========================================
# DATABASE
# ========================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/bublizi?retryWrites=true&w=majority

# ========================================
# AUTHENTICATION
# ========================================
# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ========================================
# FIREBASE ADMIN SDK
# ========================================
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ========================================
# CLERK AUTHENTICATION (Optional)
# ========================================
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key

# ========================================
# AI SERVICES
# ========================================
# Gemini AI API Key
GEMINI_API_KEY=your-gemini-api-key

# ========================================
# FILE UPLOAD (Cloudinary)
# ========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================================
# REDIS (Optional - falls back to in-memory)
# ========================================
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

# ========================================
# MONITORING & ERROR TRACKING
# ========================================
# Sentry DSN (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ========================================
# SECURITY
# ========================================
# Enable strict rate limiting in production
RATE_LIMIT_STRICT=true

# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ========================================
# FEATURES
# ========================================
# Enable performance metrics
ENABLE_METRICS=true

# Enable detailed logging
ENABLE_DEBUG_LOGS=false

# ========================================
# REDIS / UPSTASH (for rate limiting, caching, and queues)
# ========================================
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-rest-token-here"

# BullMQ Configuration (ioredis connection)
REDIS_HOST="your-redis-host.upstash.io"
REDIS_PORT=6379
REDIS_PASSWORD="your-redis-password"
REDIS_TLS=true
